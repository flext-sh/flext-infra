        if only_type_check:
            return
        subject: t.Tests.Testobject = value
        if FlextTestsMatchersUtilities._is_result_object(subject):
            result_obj = subject
            actual_value: t.Tests.TestobjectSerializable | str = ""
            if params.ok is not None:
