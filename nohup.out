            tm.fail(result, match=r"Error: \\\\d+")  # Error matches regex
    
            # Multiple error checks
            tm.fail(result, has=["invalid", "required"], lacks="internal")
    
            # Error metadata checks
            tm.fail(result, code="VALIDATION", data={"field": "email"})
    
