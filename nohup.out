        raw_contains: t.Tests.MatcherKwargValue | None = (
            kwargs.get("contains") if "contains" in kwargs else None
        )
        try:
            params = m.Tests.ThatParams.model_validate(kwargs)
        except (TypeError, ValueError, AttributeError):
