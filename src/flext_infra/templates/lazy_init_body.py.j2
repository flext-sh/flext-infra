{%- if runtime_import_lines %}
{{ runtime_import_lines }}

{% endif %}
{%- for name, value in inline_constants %}
{{ name }} = "{{ value }}"
{%- endfor %}
{%- if inline_constants %}

{% endif %}
{%- if type_checking_lines %}
import typing as _t

{{ type_checking_lines }}
{%- endif %}

{%- if child_module_paths %}
_LAZY_IMPORTS = merge_lazy_imports(
    (
{%- for child_module_path in child_module_paths %}
        "{{ child_module_path }}",
{%- endfor %}
    ),
    build_lazy_import_map(
        {
{%- for mod, names in lazy_module_groups %}
{%- if names|length == 1 %}
            "{{ mod }}": ("{{ names[0] }}",),
{%- else %}
            "{{ mod }}": (
{%- for name in names %}
                "{{ name }}",
{%- endfor %}
            ),
{%- endif %}
{%- endfor %}
        },
{%- if lazy_alias_groups %}
        alias_groups={
{%- for mod, pairs in lazy_alias_groups %}
{%- if pairs|length == 1 %}
            "{{ mod }}": (("{{ pairs[0][0] }}", "{{ pairs[0][1] }}"),),
{%- else %}
            "{{ mod }}": (
{%- for export_name, attr_name in pairs %}
                ("{{ export_name }}", "{{ attr_name }}"),
{%- endfor %}
            ),
{%- endif %}
{%- endfor %}
        },
{%- endif %}
    ),
{%- if excluded_lazy_names %}
    exclude_names=(
{%- for name in excluded_lazy_names %}
        "{{ name }}",
{%- endfor %}
    ),
{%- endif %}
    module_name=__name__,
)
{%- else %}
_LAZY_IMPORTS = build_lazy_import_map(
    {
{%- for mod, names in lazy_module_groups %}
{%- if names|length == 1 %}
        "{{ mod }}": ("{{ names[0] }}",),
{%- else %}
        "{{ mod }}": (
{%- for name in names %}
            "{{ name }}",
{%- endfor %}
        ),
{%- endif %}
{%- endfor %}
    },
{%- if lazy_alias_groups %}
    alias_groups={
{%- for mod, pairs in lazy_alias_groups %}
{%- if pairs|length == 1 %}
        "{{ mod }}": (("{{ pairs[0][0] }}", "{{ pairs[0][1] }}"),),
{%- else %}
        "{{ mod }}": (
{%- for export_name, attr_name in pairs %}
            ("{{ export_name }}", "{{ attr_name }}"),
{%- endfor %}
        ),
{%- endif %}
{%- endfor %}
    },
{%- endif %}
)
{%- endif %}

{%- if exports %}
{%- if publish_all %}

__all__ = [
{%- for export in exports %}
    "{{ export }}",
{%- endfor %}
]
{%- endif %}
{%- endif %}
