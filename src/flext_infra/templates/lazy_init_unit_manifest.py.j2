{{ autogen_header }}
"""Root lazy-import manifest — single source of truth for the {{ current_pkg }} root __init__.py.

Generated by ``make gen``. The root ``__init__.py`` consumes ONLY this module for
lazy (PEP 562) import access; sibling ``__all__`` discovery is the upstream source.
"""

from __future__ import annotations

{%- macro module_groups() %}
{%- for mod, names in lazy_module_groups %}
{%- if names|length == 1 and (mod|length + names[0]|length + 18 <= 88) %}
    "{{ mod }}": ("{{ names[0] }}",),
{%- else %}
    "{{ mod }}": (
{%- for name in names %}
        "{{ name }}",
{%- endfor %}
    ),
{%- endif %}
{%- endfor %}
{%- endmacro -%}

{%- macro alias_groups() %}
{%- for mod, pairs in lazy_alias_groups %}
    "{{ mod }}": (
{%- for export_name, attr_name in pairs %}
        ("{{ export_name }}", "{{ attr_name }}"),
{%- endfor %}
    ),
{%- endfor %}
{%- endmacro -%}

LAZY_MODULES: dict[str, tuple[str, ...]] = {
{{ module_groups() }}}

LAZY_ALIAS_GROUPS: dict[str, tuple[tuple[str, str], ...]] = {
{{ alias_groups() }}}
{% if child_module_paths %}
CHILD_MODULE_PATHS: tuple[str, ...] = (
{%- for child_module_path in child_module_paths %}
    "{{ child_module_path }}",
{%- endfor %}
)
{% else %}
CHILD_MODULE_PATHS: tuple[str, ...] = ()
{% endif %}
{% if excluded_lazy_names %}
EXCLUDED_LAZY_NAMES: frozenset[str] = frozenset({
{%- for name in excluded_lazy_names %}
    "{{ name }}",
{%- endfor %}
})
{% else %}
EXCLUDED_LAZY_NAMES: frozenset[str] = frozenset()
{% endif %}

__all__: tuple[str, ...] = (
{%- for export_name in exports %}
    "{{ export_name }}",
{%- endfor %}
)
