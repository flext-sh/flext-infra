[tool.tomlsort]
all = true
in_place = true
sort_first = [ "build-system", "project", "tool" ]
[tool.uv]
required-version = "{{ uv_required_version }}"

{% if make_profile == "workspace-root" %}
{% for repository in workspace_repositories %}
[tool.uv.sources.{{ repository.distribution }}]
git = "{{ repository.url }}"
branch = "{{ repository.branch }}"

{% endfor %}
{% else %}
[tool.uv.sources.flext-cli]
git = "{{ flext_git_base_url }}/flext-cli.git"
branch = "{{ flext_git_branch }}"

[tool.uv.sources.flext-core]
git = "{{ flext_git_base_url }}/flext-core.git"
branch = "{{ flext_git_branch }}"

[tool.uv.sources.flext-infra]
git = "{{ flext_git_base_url }}/flext-infra.git"
branch = "{{ flext_git_branch }}"

[tool.uv.sources.flext-tests]
git = "{{ flext_git_base_url }}/flext-tests.git"
branch = "{{ flext_git_branch }}"
{% endif %}

[tool.yamlfix]
explicit_start = false
line_length = 88
preserve_quotes = true
section_whitelines = 1
whitelines = 1
