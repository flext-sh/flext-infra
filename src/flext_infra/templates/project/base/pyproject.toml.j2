[tool.ruff.lint.flake8-tidy-imports.banned-api.argparse]
msg = "Use cli.register_result_command + Pydantic model from flext_cli."

[tool.ruff.lint.flake8-tidy-imports.banned-api.click]
msg = "Use flext_cli (cli, c.Cli.CliAbortError, c.Cli.CliCommandError)."

[tool.ruff.lint.flake8-tidy-imports.banned-api.rich]
msg = "Use cli.print / cli.display_message / cli.render_panel / cli.create_tree."

[tool.ruff.lint.flake8-tidy-imports.banned-api.typer]
msg = "Use cli.create_app_with_common_params / cli.register_command from flext_cli."

[tool.ruff.lint.isort]
combine-as-imports = true
force-single-line = false
known-first-party = [ "{{ package_name }}", "flext_core" ]
split-on-trailing-comma = false

