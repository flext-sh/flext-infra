# {{ dist }} — generated pyproject (FLEXT standard; ADR-005 SSOT).
# Generated by `flext-infra codegen conform`.
# NOTE (multi-agent, mro-qb4y / agent: codex): the root profile owns the local
# uv workspace; member and standalone profiles retain autonomous Git metadata.

[build-system]
build-backend = {{ scaffold.build.backend | tojson }}
requires = [
{% for item in scaffold.build.requirements %}
  {{ item | tojson }},
{% endfor %}
]

[project]
classifiers = [
{% for item in scaffold.project.classifiers %}
  {{ item | tojson }},
{% endfor %}
]
dependencies = [
{% for item in dependency_profile.runtime %}
  {{ item | tojson }},
{% endfor %}
]
description = "{{ description }}"
keywords = [
{% for item in scaffold.project.keywords %}
  {{ item | tojson }},
{% endfor %}
]
license = "{{ license }}"
name = "{{ dist }}"
readme = {{ scaffold.project.readme | tojson }}
requires-python = "{{ python_required_version }}"
version = "{{ version }}"

[[project.authors]]
email = "{{ author_email }}"
name = "{{ author_name }}"

[[project.maintainers]]
email = "{{ author_email }}"
name = "{{ author_name }}"

[dependency-groups]
codegen = [
{% for item in dependency_profile.codegen if item != dist %}
  {{ item | tojson }},
{% endfor %}
]
dev = [
{% for item in dependency_profile.dev if item != dist %}
  {{ item | tojson }},
{% endfor %}
]
workspace = [
{% for repository in workspace_repositories %}
  "{{ repository.distribution }}",
{% endfor %}
]

[project.scripts]
{{ dist }} = "{{ package_name }}.cli:main"
{% if repository %}

[project.urls]
Documentation = "{{ documentation }}"
Homepage = "{{ homepage }}"
Repository = "{{ repository }}"
{% endif %}

[tool.codespell]
check-filenames = {{ tooling.tools.codespell.check_filenames | lower }}
ignore-words-list = {{ tooling.tools.codespell.ignore_words_list | tojson }}

[tool.coverage.report]
exclude_also = [
{% for item in tooling.tools.coverage.exclude_also %}
  {{ item | tojson }},
{% endfor %}
]
fail_under = {{ tooling_runtime.coverage_fail_under }}
precision = {{ tooling.tools.coverage.precision }}
show_missing = {{ tooling.tools.coverage.show_missing | lower }}
skip_covered = {{ tooling.tools.coverage.skip_covered | lower }}

[tool.coverage.run]
source = [
{% for item in tooling.tools.coverage.source %}
  {{ item | tojson }},
{% endfor %}
]
omit = [
{% for item in tooling.tools.coverage.omit %}
  {{ item | tojson }},
{% endfor %}
]

[tool.deptry]
known_first_party = [
{% for item in tooling_runtime.first_party %}
  {{ item | tojson }},
{% endfor %}
]
pep621_dev_dependency_groups = [
{% for item in tooling.tools.deptry.pep621_dev_dependency_groups %}
  {{ item | tojson }},
{% endfor %}
]

[tool.flext.docs]
package_name = {{ package_name | tojson }}

[tool.hatch.metadata]
allow-direct-references = {{ tooling.tools.hatch.allow_direct_references | lower }}
{% if make_profile != "workspace-root" %}

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]
{% if packaged_data_dirs %}

[tool.hatch.build.targets.wheel.force-include]
{% for data_dir in packaged_data_dirs %}
{{ data_dir | tojson }} = {{ (package_name ~ "/" ~ data_dir) | tojson }}
{% endfor %}
{% endif %}

[tool.hatch.build.targets.sdist]
only-include = [
  "src/{{ package_name }}",
{% for data_dir in packaged_data_dirs %}
  {{ data_dir | tojson }},
{% endfor %}
]
{% endif %}

[tool.mypy]
