{% for code, rationale in tooling.tools.mypy.disabled_error_codes | dictsort %}
# FLEXT mypy[{{ code }}]: {{ rationale }}
{% endfor %}
disable_error_code = [
{% for code, rationale in tooling.tools.mypy.disabled_error_codes | dictsort %}
  {{ code | tojson }},
{% endfor %}
]
exclude = {{ tooling.tools.mypy.exclude | tojson }}
mypy_path = [
{% for item in tooling_runtime.mypy_path %}
  {{ item | tojson }},
{% endfor %}
]
plugins = [
{% for item in tooling.tools.mypy.plugins %}
  {{ item | tojson }},
{% endfor %}
]
python_version = {{ python_version | tojson }}
{% for key, value in tooling.tools.mypy.boolean_settings | dictsort %}
{{ key }} = {{ value | lower }}
{% endfor %}
{% for key, value in tooling.tools.mypy.string_settings | dictsort %}
{{ key }} = {{ value | tojson }}
{% endfor %}
{% for override in tooling.tools.mypy.overrides %}

[[tool.mypy.overrides]]
module = [
{% for item in override.modules %}
  {{ item | tojson }},
{% endfor %}
]
disable_error_code = [
{% for item in override.disable_error_codes %}
  {{ item | tojson }},
{% endfor %}
]
{% endfor %}

[tool.pydantic-mypy]
