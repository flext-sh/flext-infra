venv = {{ tooling_runtime.pyright_venv | tojson }}
venvPath = {{ tooling_runtime.pyright_venv_path | tojson }}
{% for setting in tooling_runtime.pyright_settings %}
{% if setting.value is boolean %}
{{ setting.name }} = {{ setting.value | lower }}
{% elif setting.value is number %}
{{ setting.name }} = {{ setting.value }}
{% else %}
{{ setting.name }} = {{ setting.value | tojson }}
{% endif %}
{% endfor %}
{% for environment in tooling_runtime.pyright_execution_environments %}

[[tool.pyright.executionEnvironments]]
root = {{ environment.root | tojson }}
extraPaths = [
{% for item in environment.extra_paths %}
  {{ item | tojson }},
{% endfor %}
]
{% for setting in environment.settings %}
{% if setting.value is boolean %}
{{ setting.name }} = {{ setting.value | lower }}
{% elif setting.value is number %}
{{ setting.name }} = {{ setting.value }}
{% else %}
{{ setting.name }} = {{ setting.value | tojson }}
{% endif %}
{% endfor %}
{% endfor %}

