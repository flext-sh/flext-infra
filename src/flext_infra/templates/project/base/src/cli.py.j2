from __future__ import annotations{# NOTE (codex, mro-j47u): consume validated config directly. #}

import sys

from flext_cli import cli

from {{ package_name }} import config, m, p, t
from {{ package_name }}.api import {{ alias }}


class {{ class_stem }}Cli:
    """Thin declarative CLI router for {{ package_name }}."""

    def __init__(self) -> None:
        """Bind the singleton facade and register the declarative routes."""
        self._service = {{ alias }}
        self._app = cli.create_app_with_common_params(
{{ app_arguments }}
        )
        self._register_commands()

    def run(self, args: t.StrSequence | None = None) -> p.Result[bool]:
        """Execute the CLI app through the public flext-cli facade."""
        result: p.Result[bool] = cli.execute_app(
            self._app, prog_name=config.{{ ns }}.name, args=args
        )
        return result

    def _register_commands(self) -> None:
        """Register the configured example result route."""
        cli.register_result_route(
            self._app,
            route=m.Cli.ResultCommandRoute(
                name=config.{{ ns }}.ping_command_name,
                help_text=config.{{ ns }}.ping_help_text,
                model_cls=m.{{ ns }}.PingInput,
                handler=self._service.ping,
                success_message=config.{{ ns }}.ping_success_message,
            ),
        )


def main() -> int:
    """Run the CLI and return a process-compatible exit code."""
    result = {{ class_stem }}Cli().run(sys.argv[1:])
    return 0 if result.success else 1


if __name__ == "__main__":
    cli.exit(main())
