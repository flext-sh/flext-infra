# Generated initially by `flext-infra codegen new`; this manifest is the
# handwritten topology SSOT consumed by `flext-infra codegen conform`.
# NOTE (multi-agent, mro-wkii.17 / agent: codex): conform never overwrites this
# input. Add members or exclusions here, then run `make codegen`.
version: 1
name: {{ dist }}
repository:
  name: {{ dist }}
  distribution: {{ dist }}
  provider: {{ repository_provider }}
  url: {{ repository_git_url }}
  branch: {{ repository_branch }}
  path: .
  role: {{ make_profile }}
  state: active
  profile: {{ make_profile }}
project:
  package_name: {{ package_name | tojson }}
  class_stem: {{ class_stem | tojson }}
  namespace: {{ ns | tojson }}
  constant_name: {{ const_name | tojson }}
  namespace_attribute: {{ ns_attr | tojson }}
  alias: {{ alias | tojson }}
  environment_prefix: {{ env_prefix | tojson }}
  description: {{ description | tojson }}
  version: {{ version | tojson }}
  license: {{ license | tojson }}
  author_name: {{ author_name | tojson }}
  author_email: {{ author_email | tojson }}
  upstream: {{ upstream | tojson }}
  homepage: {{ homepage | tojson }}
  documentation: {{ documentation | tojson }}
  workspace_root_rel: {{ workspace_root_rel | tojson }}
  year: {{ year }}
  # NOTE (mro-wkii.17.26, agent codex): declare project-only roots such as
  # ansible or docker here; common roots remain governed by codegen.yaml.
{% if project_resources %}
  resources:
{% for resource in project_resources %}
    - source: {{ resource.source | tojson }}
      required: {{ resource.required | lower }}
{% if resource.wheel_destination %}
      wheel_destination: {{ resource.wheel_destination | tojson }}
{% endif %}
{% endfor %}
{% else %}
  resources: []
{% endif %}
# NOTE (multi-agent, mro-wkii.17 / agent: codex): the typed manifest context is
# the sole topology owner; every declared member/exclusion round-trips here.
members:
{% for repository in workspace_repositories %}
  - name: {{ repository.name | tojson }}
    distribution: {{ repository.distribution | tojson }}
    provider: {{ repository.provider | tojson }}
    url: {{ repository.url | tojson }}
    branch: {{ repository.branch | tojson }}
    path: {{ repository.path | tojson }}
    role: {{ repository.role | tojson }}
    state: {{ repository.state | tojson }}
    profile: {{ repository.profile | tojson }}
{% else %}
  []
{%- endfor %}
content_only:
{% for repository in workspace_content_only %}
  - name: {{ repository.name | tojson }}
    distribution: {{ repository.distribution | tojson }}
    provider: {{ repository.provider | tojson }}
    url: {{ repository.url | tojson }}
    branch: {{ repository.branch | tojson }}
    path: {{ repository.path | tojson }}
    role: {{ repository.role | tojson }}
    state: {{ repository.state | tojson }}
    profile: {{ repository.profile | tojson }}
{% else %}
  []
{%- endfor %}
exclusions:
{% for exclusion in workspace_exclusions %}
  - path: {{ exclusion.path | tojson }}
    reason: {{ exclusion.reason | tojson }}
{% else %}
  []
{%- endfor %}
