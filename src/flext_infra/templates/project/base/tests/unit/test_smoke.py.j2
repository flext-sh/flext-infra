from __future__ import annotations

import importlib

import pytest

from {{ package_name }} import {{ class_stem }}

pytestmark = [pytest.mark.smoke, pytest.mark.unit]


def test_import_package() -> None:
    """The package imports and exposes the canonical FLEXT aliases."""
    module = importlib.import_module("{{ package_name }}")
    for alias in ("c", "m", "p", "t", "u", "r", "{{ class_stem }}", "{{ alias }}"):
        assert hasattr(module, alias), alias


def test_facade_fetch_global() -> None:
    """The public facade resolves a global instance."""
    assert {{ class_stem }}.fetch_global() is not None
