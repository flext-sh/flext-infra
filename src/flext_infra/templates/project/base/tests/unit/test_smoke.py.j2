from __future__ import annotations

from typing import TYPE_CHECKING

import pytest
from flext_tests import tm

import {{ package_name }} as pkg

if TYPE_CHECKING:
    from tests import typings as tests_typings  # noqa: F401  # typing-only import

pytestmark = [pytest.mark.smoke, pytest.mark.unit]


def test_package_exposes_canonical_aliases() -> None:
    """The package imports and exposes the canonical FLEXT aliases."""
    exported = dir(pkg)
    tm.that(exported, has="c")
    tm.that(exported, has="m")
    tm.that(exported, has="p")
    tm.that(exported, has="t")
    tm.that(exported, has="u")
    tm.that(exported, has="r")


def test_package_exposes_facade() -> None:
    """The package exposes the public facade and alias."""
    tm.that(dir(pkg), has="{{ class_stem }}")
    tm.that(dir(pkg), has="{{ alias }}")


def test_facade_fetch_global() -> None:
    """The public facade resolves a global instance via the package surface."""
    facade = getattr(pkg, "{{ class_stem }}")
    tm.that(facade.fetch_global() is not None, eq=True)


__all__: list[str] = []
