# =============================================================================
# {{ dist }} - {{ description }}
# =============================================================================
# @generated by: flext_infra workspace sync
# Run 'make sync' from workspace root to regenerate this file.
# DO NOT EDIT — put custom targets in custom.mk instead.
# =============================================================================

PROJECT_NAME := {{ dist }}
PYTHON_VERSION ?= 3.13
FLEXT_GIT_BRANCH ?= {{ flext_git_branch }}
FLEXT_GIT_BASE_URL ?= {{ flext_git_base_url }}
SRC_DIR ?= src
TESTS_DIR ?= tests
# Detect workspace root by walking up until we find the parent repo's .gitmodules.
# In a workspace, base.mk lives in flext-infra/ and is the single source of truth.
FLEXT_WORKSPACE_ROOT := $(shell \
	current="$(CURDIR)"; \
	while [ "$$current" != "/" ]; do \
		if [ -f "$$current/.gitmodules" ]; then echo "$$current"; break; fi; \
		current="$$(dirname "$$current")"; \
	done)

ifneq ($(FLEXT_WORKSPACE_ROOT),)
FLEXT_INFRA_BASE_MK := $(FLEXT_WORKSPACE_ROOT)/flext-infra/base.mk
ifneq ("$(wildcard $(FLEXT_INFRA_BASE_MK))", "")
include $(FLEXT_INFRA_BASE_MK)
else
$(error flext-infra/base.mk not found at $(FLEXT_INFRA_BASE_MK); run from a valid workspace)
endif
else
# =============================================================================
# STANDALONE BOOTSTRAP — external project (no parent workspace)
# =============================================================================
# NOTE(mro-wkii.14, agent codegen): SEM auto-rebuild de base.mk — a regra
# `base.mk: Makefile` chamando sub-make caia em RECURSAO INFINITA (o sub-make
# re-avalia `-include base.mk` ainda inexistente e dispara o rebuild de novo).
# Design: sem base.mk so existem `setup`/`help` (erro claro nos demais verbos);
# `make setup` faz o bootstrap DIRETO (sem sub-make): mise trust+install ->
# git clone das deps em .flext-deps/* (git PURO — pip install "flext-infra @
# git+..." quebrava resolvendo flext-cli do PyPI, onde nao existe) -> uv sync
# (cria .venv e instala TUDO editavel a partir de .flext-deps; sem `uv venv`,
# sem prompt --clear) -> base.mk via flext-infra (agora instalado editavel).
# Idempotente: rodar `make setup` de novo re-sincroniza tudo.
# =============================================================================

MISE ?= mise
FLEXT_INFRA_BASEMK_GROUP := basemk
# Lista fixa de deps internas = plataforma (core/cli/infra/tests).
FLEXT_INTERNAL_DEPS := flext-core flext-cli flext-infra flext-tests

-include base.mk

setup: ## Full setup: mise + clone .flext-deps + uv sync editable + base.mk
	@echo "==> Ensuring toolchains via mise (python/uv/ruff)..."
	@$(MISE) trust .mise.toml >/dev/null 2>&1 || true
	@$(MISE) install
	@echo "==> Cloning internal deps into .flext-deps/ (git, branch $(FLEXT_GIT_BRANCH))..."
	@mkdir -p .flext-deps
	@for dep in $(FLEXT_INTERNAL_DEPS); do \
		if [ ! -d ".flext-deps/$$dep/.git" ]; then \
			git clone --quiet --branch "$(FLEXT_GIT_BRANCH)" "$(FLEXT_GIT_BASE_URL)/$$dep.git" ".flext-deps/$$dep" \
				|| { echo "ERROR: git clone $$dep failed (check FLEXT_GIT_BRANCH/FLEXT_GIT_BASE_URL)"; exit 1; }; \
		fi; \
	done
	@echo "==> Installing all dependencies editable (uv sync)..."
	@$(MISE) exec -- uv sync --all-extras --all-groups
	@if git rev-parse --git-dir >/dev/null 2>&1; then \
		$(MISE) exec -- uv run pre-commit install || true; \
	fi
	@echo "==> Generating base.mk via flext-infra..."
	@$(MISE) exec -- uv run python -m flext_infra $(FLEXT_INFRA_BASEMK_GROUP) generate \
		--project-name $(PROJECT_NAME) --output base.mk
	@test -s base.mk || { echo "ERROR: base.mk generation failed"; exit 1; }
	@echo "==> Setup complete. All 'make' verbs now available (run 'make help')."

.PHONY: setup

ifeq ("$(wildcard base.mk)", "")
.PHONY: help

help: ## Show available commands
	@echo "================================================"
	@echo "  $(PROJECT_NAME) (standalone bootstrap)"
	@echo "================================================"
	@echo ""
	@echo "Bootstrap targets (no base.mk required):"

	@printf "  %-14s %s\n" "setup" "Full standalone setup (mise + deps + uv sync)"

	@printf "  %-14s %s\n" "help" "Show this help"

	@echo ""
	@echo "After 'make setup', all standard verbs become available:"
	@echo "  check, test, fmt, build, val, clean, docs, pr"
	@echo ""
	@echo "Run 'make setup' first, then 'make help' for full verb list."
endif
endif

# Project-specific targets (optional, never overwritten by sync)
-include custom.mk
