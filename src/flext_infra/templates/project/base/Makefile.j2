# =============================================================================
# {{ dist }} - {{ description }}
# =============================================================================
# @generated by: flext_infra workspace sync
# Run 'make sync' from workspace root to regenerate this file.
# DO NOT EDIT — put custom targets in custom.mk instead.
# =============================================================================

PROJECT_NAME := {{ dist }}
PYTHON_VERSION ?= 3.13
FLEXT_GIT_BRANCH ?= {{ flext_git_branch }}
FLEXT_GIT_BASE_URL ?= {{ flext_git_base_url }}
SRC_DIR ?= src
TESTS_DIR ?= tests
# Detect workspace root by walking up until we find the parent repo's .gitmodules.
# In a workspace, base.mk lives in flext-infra/ and is the single source of truth.
FLEXT_WORKSPACE_ROOT := $(shell \
	current="$(CURDIR)"; \
	while [ "$$current" != "/" ]; do \
		if [ -f "$$current/.gitmodules" ]; then echo "$$current"; break; fi; \
		current="$$(dirname "$$current")"; \
	done)

ifneq ($(FLEXT_WORKSPACE_ROOT),)
FLEXT_INFRA_BASE_MK := $(FLEXT_WORKSPACE_ROOT)/flext-infra/base.mk
ifneq ("$(wildcard $(FLEXT_INFRA_BASE_MK))", "")
include $(FLEXT_INFRA_BASE_MK)
else
$(error flext-infra/base.mk not found at $(FLEXT_INFRA_BASE_MK); run from a valid workspace)
endif
else
# =============================================================================
# STANDALONE BOOTSTRAP — external project (no parent workspace)
# =============================================================================
# NOTE(mro-wkii.14, agent codegen): local dev uses editable git SUBMODULES WITHOUT
# touching pyproject (which declares flext-* ONLY via git+branch = portable origin).
# Flow (validated by Oracle/uv docs): mise trust+install -> git submodule add of
# each flext-* under .flext-src/<pkg> -> `uv sync` resolves/installs from GITHUB (git
# sources in pyproject; uv.lock pins the SHA) -> editable overlay `uv pip install -e
# .flext-src/<pkg> --no-deps --no-sources` (.pth link in .venv; --no-sources stops
# the build from lowering the submodule's own [tool.uv.sources] and failing with
# 'not a workspace member'). `uv sync` is EXACT and reverts the editable back to the
# git-pinned build; that is why the overlay lives in the `sync` target (every sync
# re-applies it) and UV_NO_SYNC=1 (set in the env via mise/base.mk) makes `uv run`
# use the overlaid .venv instead of reverting. Idempotent: `git submodule status` guard.
# uv LIMITATION (uv#12013): there is no way to install a git dep as editable from a
# local path without writing that path into pyproject; this overlay lives outside the
# lockfile model -> CI (no overlay) uses the uv.lock SHA, dev uses the local checkout.
# uv.lock is the SSOT for reproducibility.
# =============================================================================

MISE ?= mise
FLEXT_INFRA_BASEMK_GROUP := basemk
# Internal platform deps, registered as editable git submodules for local dev.
FLEXT_DEPS := flext-core flext-cli flext-infra flext-tests

-include base.mk

setup: ## Full setup: mise + git submodules (.flext-src) + uv sync + editable overlay + base.mk
	@echo "==> Ensuring toolchains via mise (python/uv/ruff)..."
	@$(MISE) trust .mise.toml >/dev/null 2>&1 || true
	@$(MISE) install
	@echo "==> Registering internal deps as git submodules in .flext-src/ (branch $(FLEXT_GIT_BRANCH))..."
	@for dep in $(FLEXT_DEPS); do \
		git submodule status ".flext-src/$$dep" >/dev/null 2>&1 \
			|| git submodule add -b "$(FLEXT_GIT_BRANCH)" "$(FLEXT_GIT_BASE_URL)/$$dep.git" ".flext-src/$$dep" \
			|| { echo "ERROR: git submodule add $$dep failed (check FLEXT_GIT_BRANCH/FLEXT_GIT_BASE_URL)"; exit 1; }; \
	done
	@git submodule update --init --recursive
	@$(MAKE) sync
	@if git rev-parse --git-dir >/dev/null 2>&1; then $(MISE) exec -- uv run pre-commit install || true; fi
	@echo "==> Generating base.mk via flext-infra..."
	@$(MISE) exec -- uv run python -m flext_infra $(FLEXT_INFRA_BASEMK_GROUP) generate \
		--project-name $(PROJECT_NAME) --output base.mk
	@test -s base.mk || { echo "ERROR: base.mk generation failed"; exit 1; }
	@echo "==> Setup complete. All 'make' verbs now available (run 'make help')."

sync: ## Resolve from committed git sources, then re-apply the editable submodule overlay
	@echo "==> uv sync (git sources from pyproject; uv.lock pins SHAs)..."
	@$(MISE) exec -- uv sync --all-extras --all-groups
	@echo "==> Applying editable overlay for .flext-src/* (uv pip install -e --no-deps --no-sources)..."
	@for dep in $(FLEXT_DEPS); do \
		test -d ".flext-src/$$dep" \
			&& $(MISE) exec -- uv pip install -e ".flext-src/$$dep" --no-deps --no-sources \
			|| echo "  (skip $$dep: submodule not present; run 'make setup')"; \
	done

.PHONY: setup sync

ifeq ("$(wildcard base.mk)", "")
.PHONY: help

help: ## Show available commands
	@echo "================================================"
	@echo "  $(PROJECT_NAME) (standalone bootstrap)"
	@echo "================================================"
	@echo ""
	@echo "Bootstrap targets (no base.mk required):"

	@printf "  %-14s %s\n" "setup" "First-time bootstrap (mise + submodules + uv sync + overlay)"

	@printf "  %-14s %s\n" "sync" "Re-resolve git sources + re-apply editable overlay"

	@printf "  %-14s %s\n" "help" "Show this help"

	@echo ""
	@echo "After 'make setup', all standard verbs become available:"
	@echo "  check, test, fmt, build, val, clean, docs, pr"
	@echo ""
	@echo "Run 'make setup' first, then 'make help' for full verb list."
endif
endif

# Project-specific targets (optional, never overwritten by sync)
-include custom.mk
