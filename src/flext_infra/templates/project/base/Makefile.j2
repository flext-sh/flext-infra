# {{ dist }} — generated development interface.
# Generated by `flext-infra codegen conform`; edit only `custom.mk`.
# NOTE (multi-agent, mro-wkii.17.4 / agent: codex): this file is the complete
# Make SSOT output. It deliberately has no external framework include,
# bootstrap, alias, sibling discovery, or regeneration side effect.

SHELL := /bin/sh
.DEFAULT_GOAL := help

PROJECT_NAME := {{ dist }}
MAKE_PROFILE := {{ make_profile }}
WORKSPACE_ROOT_REL := {{ workspace_root_rel }}
WORKSPACE_MEMBERS :={% for member in workspace_members %} {{ member }}{% endfor %}
WORKSPACE_EDITABLES := $(PROJECT_NAME):.{% for repository in workspace_repositories %} {{ repository.distribution }}:{{ repository.path }}{% endfor %}
PYTHON_VERSION := 3.13.11
UV_REQUIRED_VERSION := 0.11.28

APPLY ?= N
ARGS ?=
PROJECTS ?=
VERSION ?=
WHAT ?=

PROJECT_ROOT := $(shell pwd -P)

ifneq ($(filter $(MAKE_PROFILE),workspace-root workspace-member standalone),$(MAKE_PROFILE))
$(error Invalid MAKE_PROFILE '$(MAKE_PROFILE)')
endif

ifeq ($(MAKE_PROFILE),workspace-member)
DECLARED_WORKSPACE_ROOT := $(shell cd "$(PROJECT_ROOT)/$(WORKSPACE_ROOT_REL)" 2>/dev/null && pwd -P)
SUPERPROJECT_ROOT_RAW := $(shell git rev-parse --show-superproject-working-tree 2>/dev/null)
SUPERPROJECT_ROOT := $(shell test -n "$(SUPERPROJECT_ROOT_RAW)" && cd "$(SUPERPROJECT_ROOT_RAW)" 2>/dev/null && pwd -P)
ifeq ($(SUPERPROJECT_ROOT),$(DECLARED_WORKSPACE_ROOT))
ATTACHED_MEMBER := Y
RUNTIME_ROOT := $(DECLARED_WORKSPACE_ROOT)
else
ATTACHED_MEMBER := N
RUNTIME_ROOT := $(PROJECT_ROOT)
endif
else
ATTACHED_MEMBER := N
RUNTIME_ROOT := $(PROJECT_ROOT)
endif

ifeq ($(MAKE_PROFILE),workspace-root)
CODEGEN_SCOPE := all
ALLOWED_PROJECTS := . $(WORKSPACE_MEMBERS)
else
CODEGEN_SCOPE := self
ALLOWED_PROJECTS := .
endif

UV_RUN := uv run --project "$(RUNTIME_ROOT)" --no-sync
CHECK_PATHS := $(PROJECT_ROOT)/src $(PROJECT_ROOT)/tests

-include custom.mk

_DEFAULT_help := default
_DEFAULT_setup := default
_DEFAULT_deps := check
_DEFAULT_build := package
_DEFAULT_check := default
_DEFAULT_test := default
_DEFAULT_format := $(if $(filter Y,$(APPLY)),apply,check)
_DEFAULT_run := default
_DEFAULT_status := default
_DEFAULT_docs := build
_DEFAULT_clean := default
_DEFAULT_release := check
_DEFAULT_codegen := $(if $(filter Y,$(APPLY)),apply,check)

_BUILTIN_HANDLERS := \
	_builtin_help_default \
	_builtin_setup_default \
	_builtin_deps_check \
	_builtin_deps_lock \
	_builtin_deps_upgrade \
	_builtin_build_package \
	_builtin_check_default \
	_builtin_test_default \
	_builtin_format_check \
	_builtin_format_apply \
	_builtin_run_default \
	_builtin_status_default \
	_builtin_docs_build \
	_builtin_clean_default \
	_builtin_release_check \
	_builtin_release_tag \
	_builtin_release_pr \
	_builtin_release_publish \
	_builtin_codegen_check \
	_builtin_codegen_apply

define _dispatch
	@what="$(strip $(WHAT))"; \
	if [ -z "$$what" ]; then what="$(_DEFAULT_$@)"; fi; \
	case "$$what" in \
		*[!a-z0-9_-]*|'') echo "ERROR: invalid WHAT selector '$$what'" >&2; exit 2 ;; \
	esac; \
	builtin="_builtin_$@_$$what"; \
	custom="_custom_$@_$$what"; \
	case " $(_BUILTIN_HANDLERS) " in \
		*" $$builtin "*) exec $(MAKE) --no-print-directory "$$builtin" ;; \
		*) exec $(MAKE) --no-print-directory "$$custom" ;; \
	esac
endef

define _require_apply
	@if [ "$(APPLY)" != "Y" ]; then \
		echo "ERROR: this action requires APPLY=Y" >&2; \
		exit 2; \
	fi
endef

define _run_for_selected_projects
	@set -eu; \
	selected="$(strip $(PROJECTS))"; \
	if [ -z "$$selected" ]; then selected="."; fi; \
	for project in $$selected; do \
		case " $(ALLOWED_PROJECTS) " in \
			*" $$project "*) ;; \
			*) echo "ERROR: undeclared project '$$project'" >&2; exit 2 ;; \
		esac; \
		uv lock --project "$(PROJECT_ROOT)/$$project" $(1); \
	done
endef

.PHONY: help setup deps build check test format run status docs clean release codegen

help setup deps build check test format run status docs clean release codegen:
	$(call _dispatch)

.PHONY: $(_BUILTIN_HANDLERS)

_builtin_help_default:
	@printf '%s\n' \
		'$(PROJECT_NAME) [$(MAKE_PROFILE)]' \
		'' \
		'  help     WHAT=default' \
		'  setup    WHAT=default' \
		'  deps     WHAT=check|lock|upgrade [PROJECTS="..."] [APPLY=Y]' \
		'  build    WHAT=package' \
		'  check    WHAT=default' \
		'  test     WHAT=default' \
		'  format   WHAT=check|apply [APPLY=Y]' \
		'  run      WHAT=default [ARGS="..."]' \
		'  status   WHAT=default' \
		'  docs     WHAT=build' \
		'  clean    WHAT=default' \
		'  release  WHAT=check|tag|pr|publish [APPLY=Y]' \
		'  codegen  WHAT=check|apply [APPLY=Y]'

ifeq ($(MAKE_PROFILE),workspace-root)
_builtin_setup_default:
	@mise install
	@set -eu; \
	for member in $(WORKSPACE_MEMBERS); do \
		test -f "$(PROJECT_ROOT)/$$member/pyproject.toml" || { \
			echo "ERROR: declared member '$$member' has no pyproject.toml" >&2; exit 2; \
		}; \
		state=$$(git -C "$(PROJECT_ROOT)" submodule status -- "$$member") || { \
			echo "ERROR: declared member '$$member' is not a registered submodule" >&2; exit 2; \
		}; \
		case "$$state" in -*|+*|U*) \
			echo "ERROR: submodule '$$member' is not at its registered revision: $$state" >&2; exit 2 ;; \
		esac; \
	done
	@uv sync --project "$(PROJECT_ROOT)" --locked --all-groups
	@set -eu; \
	python="$(PROJECT_ROOT)/.venv/bin/python"; \
	uv pip install --python "$$python" --no-deps --editable "$(PROJECT_ROOT)"; \
	for member in $(WORKSPACE_MEMBERS); do \
		uv pip install --python "$$python" --no-deps --editable "$(PROJECT_ROOT)/$$member"; \
	done; \
	uv pip check --python "$$python"; \
	site_packages=$$(find "$(PROJECT_ROOT)/.venv/lib" -type d -name site-packages -print -quit); \
	test -n "$$site_packages" || { echo "ERROR: root site-packages not found" >&2; exit 2; }; \
	for editable in $(WORKSPACE_EDITABLES); do \
		distribution=$${editable%%:*}; \
		checkout=$${editable#*:}; \
		$(UV_RUN) python -c 'import json,re,sys; from pathlib import Path; site=Path(sys.argv[1]); dist=re.sub(r"[-_.]+", "_", sys.argv[2]).lower(); expected=Path(sys.argv[3]).resolve().as_uri(); matches=[path for path in site.glob(f"{dist}-*.dist-info/direct_url.json") if (payload := json.loads(path.read_text(encoding="utf-8"))).get("url") == expected and payload.get("dir_info", {}).get("editable") is True]; raise SystemExit(0 if matches else f"ERROR: editable direct_url.json mismatch for {sys.argv[2]} at {expected}")' "$$site_packages" "$$distribution" "$(PROJECT_ROOT)/$$checkout"; \
	done
else ifeq ($(MAKE_PROFILE),workspace-member)
ifeq ($(ATTACHED_MEMBER),Y)
_builtin_setup_default:
	@$(MAKE) --no-print-directory -C "$(RUNTIME_ROOT)" setup
else
_builtin_setup_default:
	@mise install
	@uv sync --project "$(PROJECT_ROOT)" --locked --all-groups
endif
else
_builtin_setup_default:
	@mise install
	@uv sync --project "$(PROJECT_ROOT)" --locked --all-groups
endif

_builtin_deps_check:
	$(call _run_for_selected_projects,--check)

_builtin_deps_lock:
	$(call _require_apply)
	$(call _run_for_selected_projects,)

_builtin_deps_upgrade:
	$(call _require_apply)
	$(call _run_for_selected_projects,--upgrade)

_builtin_build_package:
	@uv build --project "$(PROJECT_ROOT)"

_builtin_check_default:
	@$(UV_RUN) ruff check --no-fix $(CHECK_PATHS)
	@$(UV_RUN) pyrefly check $(CHECK_PATHS)

_builtin_test_default:
	@$(UV_RUN) pytest "$(PROJECT_ROOT)/tests"

_builtin_format_check:
	@$(UV_RUN) ruff format --check $(CHECK_PATHS)

_builtin_format_apply:
	$(call _require_apply)
	@$(UV_RUN) ruff format $(CHECK_PATHS)

_builtin_run_default:
	@$(UV_RUN) $(PROJECT_NAME) $(ARGS)

_builtin_status_default:
	@printf 'profile=%s\nattached=%s\nproject=%s\nruntime=%s\n' \
		'$(MAKE_PROFILE)' '$(ATTACHED_MEMBER)' '$(PROJECT_ROOT)' '$(RUNTIME_ROOT)'
	@uv --version
	@uv lock --project "$(PROJECT_ROOT)" --check
	@if [ -x "$(RUNTIME_ROOT)/.venv/bin/python" ]; then \
		uv pip check --python "$(RUNTIME_ROOT)/.venv/bin/python"; \
	fi
	@git -C "$(PROJECT_ROOT)" status --short

_builtin_docs_build:
	@$(UV_RUN) mkdocs build --strict --config-file "$(PROJECT_ROOT)/mkdocs.yml"

_builtin_clean_default:
	@find "$(PROJECT_ROOT)" -type d \
		\( -name __pycache__ -o -name .mypy_cache -o -name .pytest_cache -o -name .ruff_cache \) \
		-prune -exec rm -rf {} +
	@rm -rf "$(PROJECT_ROOT)/build" "$(PROJECT_ROOT)/dist" "$(PROJECT_ROOT)/htmlcov"
	@rm -f "$(PROJECT_ROOT)/.coverage"

_builtin_release_check:
	@uv lock --project "$(PROJECT_ROOT)" --check
	@git -C "$(PROJECT_ROOT)" diff --quiet
	@git -C "$(PROJECT_ROOT)" diff --cached --quiet

_builtin_release_tag:
	$(call _require_apply)
	@test -n "$(VERSION)" || { echo "ERROR: VERSION is required" >&2; exit 2; }
	@git -C "$(PROJECT_ROOT)" tag -a "$(VERSION)" -m "Release $(VERSION)"

_builtin_release_pr:
	$(call _require_apply)
	@cd "$(PROJECT_ROOT)" && gh pr create $(ARGS)

_builtin_release_publish:
	$(call _require_apply)
	@uv publish "$(PROJECT_ROOT)"/dist/*

_builtin_codegen_check:
	@$(UV_RUN) flext-infra codegen conform --root "$(PROJECT_ROOT)" --scope "$(CODEGEN_SCOPE)" --mode check

_builtin_codegen_apply:
	$(call _require_apply)
	@$(UV_RUN) flext-infra codegen conform --root "$(PROJECT_ROOT)" --scope "$(CODEGEN_SCOPE)" --mode apply
