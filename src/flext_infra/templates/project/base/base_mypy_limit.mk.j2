# === MYPY RESOURCE LIMIT ===
# mro-0ftd.3.11: every Mypy process inherits validated memory and time caps.
MYPY_MEMORY_LIMIT_MB ?= {{ mypy_memory_limit_mb }}
MYPY_TIMEOUT_SECONDS ?= {{ mypy_timeout_seconds }}
MYPY_BOUNDED = {{ timeout_command }} --signal=TERM --kill-after={{ timeout_kill_after_seconds }}s "$(MYPY_TIMEOUT_SECONDS)s" {{ prlimit_command }} {{ prlimit_address_space_option }}=$$(( $(MYPY_MEMORY_LIMIT_MB) * 1024 * 1024 )):$$(( $(MYPY_MEMORY_LIMIT_MB) * 1024 * 1024 )) --
VALIDATE_MYPY_LIMITS = case "$(MYPY_MEMORY_LIMIT_MB)" in ""|*[!0-9]*) echo "ERROR: MYPY_MEMORY_LIMIT_MB must be a positive integer"; exit 2;; esac; [ "$(MYPY_MEMORY_LIMIT_MB)" -gt 0 ] || { echo "ERROR: MYPY_MEMORY_LIMIT_MB must be greater than zero"; exit 2; }; [ "$(MYPY_MEMORY_LIMIT_MB)" -le {{ mypy_memory_limit_mb }} ] || { echo "ERROR: MYPY_MEMORY_LIMIT_MB must be less than or equal to {{ mypy_memory_limit_mb }}"; exit 2; }; case "$(MYPY_TIMEOUT_SECONDS)" in ""|*[!0-9]*) echo "ERROR: MYPY_TIMEOUT_SECONDS must be a positive integer"; exit 2;; esac; [ "$(MYPY_TIMEOUT_SECONDS)" -gt 0 ] || { echo "ERROR: MYPY_TIMEOUT_SECONDS must be greater than zero"; exit 2; }; [ "$(MYPY_TIMEOUT_SECONDS)" -le {{ mypy_timeout_seconds }} ] || { echo "ERROR: MYPY_TIMEOUT_SECONDS must be less than or equal to {{ mypy_timeout_seconds }}"; exit 2; }; command -v {{ timeout_command }} >/dev/null 2>&1 || { echo "ERROR: required executable not found: {{ timeout_command }}"; exit 2; }; command -v {{ prlimit_command }} >/dev/null 2>&1 || { echo "ERROR: required executable not found: {{ prlimit_command }}"; exit 2; }
REPORT_MYPY_FAILURE = code=$$?; signal=none; if [ "$$code" -ge {{ mypy_signal_exit_offset }} ]; then signal=$$(( $$code - {{ mypy_signal_exit_offset }} )); fi; echo "ERROR: bounded Mypy execution failed: memory_limit=$(MYPY_MEMORY_LIMIT_MB) MiB; timeout=$(MYPY_TIMEOUT_SECONDS)s; exit=$$code; signal=$$signal" >&2
export MYPY_MEMORY_LIMIT_MB MYPY_TIMEOUT_SECONDS
