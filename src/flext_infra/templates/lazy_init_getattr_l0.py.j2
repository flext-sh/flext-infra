__all__: list[str] = [
{%- for name in exports %}
    "{{ name }}",
{%- endfor %}
]


def __getattr__(name: str) -> type:
    if name in _LAZY_IMPORTS:
        entry = _LAZY_IMPORTS[name]
        if isinstance(entry, str):
            mod, attr = entry, name
        else:
            mod, attr = entry[0], entry[1]
        loaded = importlib.import_module(mod)
        if not attr:
            globals()[name] = loaded
            return loaded
        resolved = getattr(loaded, attr)
        globals()[name] = resolved
        return resolved
    msg = f"module {__name__!r} has no attribute {name!r}"
    raise AttributeError(msg)


def __dir__() -> Sequence[str]:
    return sorted(__all__)


_current = sys.modules.get(__name__)
if _current is not None:
    _parts = __name__.split(".")
    for _lazy_val in _LAZY_IMPORTS.values():
        _mod_path = _lazy_val if isinstance(_lazy_val, str) else _lazy_val[0]
        if _mod_path:
            _mp = _mod_path.split(".")
            if len(_mp) > len(_parts) and _mp[: len(_parts)] == _parts:
                _sub = getattr(_current, _mp[len(_parts)], None)
                if _sub is not None and isinstance(_sub, type(sys)):
                    delattr(_current, _mp[len(_parts)])
