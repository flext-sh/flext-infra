{{ autogen_header }}
"""Lazy export registry."""

from __future__ import annotations

from flext_core.lazy import build_lazy_import_map, merge_lazy_imports

_LOCAL_LAZY_IMPORTS = build_lazy_import_map(
    {
{%- for mod, names in lazy_module_groups %}
{%- if names|length == 1 and (mod|length + names[0]|length + 18 <= 88) %}
        "{{ mod }}": ("{{ names[0] }}",),
{%- else %}
        "{{ mod }}": (
{%- for name in names %}
            "{{ name }}",
{%- endfor %}
        ),
{%- endif %}
{%- endfor %}
    },
{%- if lazy_alias_groups %}
    alias_groups={
{%- for mod, pairs in lazy_alias_groups %}
{%- if pairs|length == 1 and (mod|length + pairs[0][0]|length + pairs[0][1]|length + 25 <= 88) %}
        "{{ mod }}": (("{{ pairs[0][0] }}", "{{ pairs[0][1] }}"),),
{%- else %}
        "{{ mod }}": (
{%- for export_name, attr_name in pairs %}
            ("{{ export_name }}", "{{ attr_name }}"),
{%- endfor %}
        ),
{%- endif %}
{%- endfor %}
    },
{%- endif %}
)

{{ registry_name }} = merge_lazy_imports(
{%- if child_module_paths|length == 1 %}
    ("{{ child_module_paths[0] }}",),
{%- else %}
    (
{%- for child_module_path in child_module_paths %}
        "{{ child_module_path }}",
{%- endfor %}
    ),
{%- endif %}
    _LOCAL_LAZY_IMPORTS,
{%- if excluded_lazy_names %}
    exclude_names=(
{%- for name in excluded_lazy_names %}
        "{{ name }}",
{%- endfor %}
    ),
{%- endif %}
    module_name="{{ current_pkg }}",
)

__all__: list[str] = ["{{ registry_name }}"]
