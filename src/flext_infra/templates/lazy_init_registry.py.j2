{{ autogen_header }}
"""Lazy export registry."""

from __future__ import annotations

from flext_core.lazy import merge_lazy_imports
{%- for module, part_name in part_imports %}
from {{ module }} import {{ part_name }}
{%- endfor %}

_LOCAL_LAZY_IMPORTS = {
{%- for module, part_name in part_imports %}
    **{{ part_name }},
{%- endfor %}
}

{{ registry_name }} = merge_lazy_imports(
{%- if child_module_paths|length == 1 %}
    ("{{ child_module_paths[0] }}",),
{%- else %}
    (
{%- for child_module_path in child_module_paths %}
        "{{ child_module_path }}",
{%- endfor %}
    ),
{%- endif %}
    _LOCAL_LAZY_IMPORTS,
{%- if excluded_lazy_names %}
    exclude_names=(
{%- for name in excluded_lazy_names %}
        "{{ name }}",
{%- endfor %}
    ),
{%- endif %}
    module_name="{{ current_pkg }}",
)

__all__: list[str] = ["{{ registry_name }}"]
