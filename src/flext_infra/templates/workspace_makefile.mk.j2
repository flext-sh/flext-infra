_types: ## Validate typed dependencies/protocol contracts without generated stubs. Use PROJECT= or PROJECTS= to scope.
	$(Q)$(PREPARE_RUNTIME_SELECTED_PROJECTS)
	$(Q)echo "Validating typed dependency policy (no generated .pyi/stubgen route)..."
	$(Q)if [ -d "$(CURDIR)/typings" ]; then \
		echo "ERROR: root typings/ is forbidden; install types-* packages or model contracts in p.* protocols"; \
		exit 1; \
	fi
	$(Q)stub_file=$$(find "$(CURDIR)" \
		-path "$(CURDIR)/.git" -prune -o \
		-path "$(CURDIR)/.venv" -prune -o \
		-path "$(CURDIR)/.reports" -prune -o \
		-name '*.pyi' -print -quit); \
	if [ -n "$$stub_file" ]; then \
		echo "ERROR: .pyi stub file is forbidden: $$stub_file"; \
		echo "Install a types-* package or create the owning p.* protocol instead."; \
		exit 1; \
	fi
	$(Q)$(WORKSPACE_INFRA_VALIDATE) stub-validate \
		$(if $(SELECTED_PROJECT_FLAGS),$(SELECTED_PROJECT_FLAGS),--all)
	$(Q)if [ "$(DEPS_REPORT)" != "0" ]; then \
		printf "Dependency report (deptry + pip check)... "; \
		report_ts=$$(date +%s); \
		if $(WORKSPACE_INFRA_DEPS) detect --typings --quiet --no-fail --output "$(CURDIR)/.reports/dependencies/detect-runtime-dev-latest.json"; then \
			report_elapsed=$$(( $$(date +%s) - report_ts )); \
			echo "ok ($${report_elapsed}s)"; \
		else \
			echo "failed"; \
			exit 1; \
		fi; \
	fi

_pyre: ## Authoritative repo-wide pyrefly report + policy gate -> .reports/pyrefly
	$(Q)$(REQUIRE_VENV)
	$(Q)$(ENFORCE_WORKSPACE_VENV)
	$(Q)mkdir -p .reports/pyrefly
	$(Q)set -o pipefail; \
	$(WORKSPACE_INFRA_CHECK) run \
		--gates pyrefly \
		--reports-dir "$(CURDIR)/.reports/pyrefly" \
		--projects "." \
		2>&1 | tee .reports/pyrefly/pyrefly-repo-before.txt; \
	pyre_status=$${PIPESTATUS[0]}; \
	printf "exit_code: %s\n" "$$pyre_status" >> .reports/pyrefly/pyrefly-repo-before.txt; \
	if [ "$$pyre_status" -ne 0 ]; then \
		echo "WARNING: pyrefly reported $$pyre_status (see .reports/pyrefly/ for details)"; \
	fi; \
	echo ""; \
	echo "=== Type Policy Gate ==="; \
	policy_violations=0; \
	echo "--- # type: ignore ---"; \
	$(WORKSPACE_INFRA_VALIDATE) scan --workspace . \
		--pattern "#\\s*type:\\s*ignore" \
		--include "**/*.py*" \
		--exclude "**/.venv/**" --exclude "**/venv/**" --exclude "**/__pycache__/**" --exclude "**/.git/**" \
		--exclude "**/*.pyc" --exclude "**/*.pyo" \
		--exclude ".reports/**" --exclude "**/*.bak" \
		--exclude "**/_constants/enforcement.py" \
		--exclude "**/_utilities/_beartype/**" \
		--exclude "**/typings.py" --exclude "**/typings/**" \
		--exclude "**/tests/fixtures/**" \
		--match absent \
		2>&1 || policy_violations=$$((policy_violations + 1)); \
	echo "--- Dynamic typing policy ---"; \
	$(WORKSPACE_INFRA_VALIDATE) scan --workspace . \
		--pattern "\\bAny\\b" \
		--include "**/*.py*" \
		--exclude "**/.venv/**" --exclude "**/venv/**" --exclude "**/__pycache__/**" --exclude "**/.git/**" \
		--exclude "**/*.pyc" --exclude "**/*.pyo" \
		--exclude ".reports/**" --exclude "**/*.bak" \
		--exclude "**/_constants/enforcement.py" \
		--exclude "**/_utilities/_beartype/**" \
		--exclude "**/typings.py" --exclude "**/typings/**" \
		--exclude "**/tests/fixtures/**" \
		--match absent \
		2>&1 || policy_violations=$$((policy_violations + 1)); \
	echo "--- object annotations ---"; \
	$(WORKSPACE_INFRA_VALIDATE) scan --workspace . \
		--pattern "(?::\\s*|->\\s*)object\\b" \
		--include "**/*.py*" \
		--exclude "**/.venv/**" --exclude "**/venv/**" --exclude "**/__pycache__/**" --exclude "**/.git/**" \
		--exclude "**/*.pyc" --exclude "**/*.pyo" \
		--exclude ".reports/**" --exclude "**/*.bak" \
		--exclude "**/_constants/enforcement.py" \
		--exclude "**/_utilities/_beartype/**" \
		--exclude "**/typings.py" --exclude "**/typings/**" \
		--exclude "**/tests/fixtures/**" \
		--match absent \
		2>&1 || policy_violations=$$((policy_violations + 1)); \
	if [ "$$policy_violations" -gt 0 ]; then \
		echo ""; \
		echo "FAIL: $$policy_violations policy violation category(ies) found"; \
		exit 1; \
	fi; \
	echo ""; \
	echo "OK: pyrefly + type policy gate passed"

