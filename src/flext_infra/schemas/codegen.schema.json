{
  "$defs": {
    "CodegenConfigNamespaceSpec": {
      "additionalProperties": false,
      "description": "Typed ``Infra`` namespace stored in ``config/codegen.yaml``.",
      "properties": {
        "codegen": {
          "$ref": "#/$defs/CodegenConfigSpec",
          "description": "Canonical code-generation configuration"
        }
      },
      "required": [
        "codegen"
      ],
      "title": "CodegenConfigNamespaceSpec",
      "type": "object"
    },
    "CodegenConfigSpec": {
      "additionalProperties": false,
      "description": "Fully modeled content of ``config/codegen.yaml``.",
      "properties": {
        "grpc": {
          "$ref": "#/$defs/GrpcCodegenSpec",
          "description": "gRPC generated-source normalization policy"
        },
        "make": {
          "$ref": "#/$defs/MakeSpec",
          "description": "Canonical Make contract"
        },
        "managed_files": {
          "description": "Files owned by conform",
          "items": {
            "$ref": "#/$defs/ManagedFileSpec"
          },
          "title": "Managed Files",
          "type": "array"
        },
        "profiles": {
          "description": "Ordered Make profiles",
          "items": {
            "$ref": "#/$defs/ProfileSpec"
          },
          "title": "Profiles",
          "type": "array"
        },
        "providers": {
          "description": "Ordered Git providers",
          "items": {
            "$ref": "#/$defs/ProviderSpec"
          },
          "title": "Providers",
          "type": "array"
        },
        "repositories": {
          "description": "Ordered repository catalog",
          "items": {
            "$ref": "#/$defs/RepositoryRef"
          },
          "title": "Repositories",
          "type": "array"
        },
        "scaffold": {
          "$ref": "#/$defs/ScaffoldSpec",
          "description": "Typed new-project scaffold policy"
        },
        "templates": {
          "$ref": "#/$defs/TemplatesSpec",
          "description": "New-project-only scaffold template manifest"
        },
        "toolchain": {
          "$ref": "#/$defs/ToolchainSpec",
          "description": "Exact generated toolchain"
        },
        "version": {
          "description": "Config schema version",
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        },
        "workspaces": {
          "description": "Pointers to local workspace topology manifests",
          "items": {
            "$ref": "#/$defs/WorkspaceCatalogRef"
          },
          "title": "Workspaces",
          "type": "array"
        }
      },
      "required": [
        "version",
        "grpc",
        "toolchain",
        "providers",
        "profiles",
        "make",
        "managed_files",
        "scaffold",
        "templates",
        "repositories",
        "workspaces"
      ],
      "title": "CodegenConfigSpec",
      "type": "object"
    },
    "CustomHandlerPolicy": {
      "additionalProperties": false,
      "description": "Strict schema for the only handwritten Make extension file.",
      "properties": {
        "allow_generated_target_redefinition": {
          "description": "Permit generated target redefinition",
          "title": "Allow Generated Target Redefinition",
          "type": "boolean"
        },
        "allow_help_declarations": {
          "description": "Permit help declarations",
          "title": "Allow Help Declarations",
          "type": "boolean"
        },
        "allow_public_targets": {
          "description": "Permit public targets",
          "title": "Allow Public Targets",
          "type": "boolean"
        },
        "allow_setup_declarations": {
          "description": "Permit setup declarations",
          "title": "Allow Setup Declarations",
          "type": "boolean"
        },
        "allow_toolchain_declarations": {
          "description": "Permit toolchain declarations",
          "title": "Allow Toolchain Declarations",
          "type": "boolean"
        },
        "filename": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Versioned custom handler filename"
        },
        "target_pattern": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Required private target regular expression"
        }
      },
      "required": [
        "filename",
        "target_pattern",
        "allow_public_targets",
        "allow_generated_target_redefinition",
        "allow_toolchain_declarations",
        "allow_setup_declarations",
        "allow_help_declarations"
      ],
      "title": "CustomHandlerPolicy",
      "type": "object"
    },
    "GrpcCodegenSpec": {
      "additionalProperties": false,
      "description": "Canonical normalization policy for official compiler modules.",
      "properties": {
        "ruff_safe_fixes": {
          "description": "Ordered safe Ruff fix selectors",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "minItems": 1,
          "title": "Ruff Safe Fixes",
          "type": "array"
        }
      },
      "required": [
        "ruff_safe_fixes"
      ],
      "title": "GrpcCodegenSpec",
      "type": "object"
    },
    "MakeProfile": {
      "description": "Generated Makefile profile for one repository.",
      "enum": [
        "workspace-root",
        "workspace-member",
        "standalone"
      ],
      "title": "MakeProfile",
      "type": "string"
    },
    "MakeSpec": {
      "additionalProperties": false,
      "description": "Complete generated Makefile public and extension contract.",
      "properties": {
        "apply_value": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Only accepted write-enable value"
        },
        "apply_variable": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Write-enable variable name"
        },
        "custom_handler_policy": {
          "$ref": "#/$defs/CustomHandlerPolicy",
          "description": "Private custom target policy"
        },
        "selector": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Single selector variable name"
        },
        "verbs": {
          "description": "Ordered canonical public verbs",
          "items": {
            "$ref": "#/$defs/MakeVerbSpec"
          },
          "title": "Verbs",
          "type": "array"
        }
      },
      "required": [
        "selector",
        "apply_variable",
        "apply_value",
        "verbs",
        "custom_handler_policy"
      ],
      "title": "MakeSpec",
      "type": "object"
    },
    "MakeVerbSpec": {
      "additionalProperties": false,
      "description": "One public Make verb and its single default selector.",
      "properties": {
        "apply_guarded": {
          "default": false,
          "description": "Whether mutation requires APPLY=Y",
          "title": "Apply Guarded",
          "type": "boolean"
        },
        "default_what": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Default WHAT selector"
        },
        "name": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Public Make verb"
        }
      },
      "required": [
        "name",
        "default_what"
      ],
      "title": "MakeVerbSpec",
      "type": "object"
    },
    "ManagedFileSpec": {
      "additionalProperties": false,
      "description": "One versioned file owned by codegen.",
      "properties": {
        "overwrite": {
          "description": "Whether clean committed content may be replaced",
          "title": "Overwrite",
          "type": "boolean"
        },
        "owner": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Canonical owner"
        },
        "path": {
          "description": "Repository-relative file path",
          "format": "path",
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "path",
        "owner",
        "overwrite"
      ],
      "title": "ManagedFileSpec",
      "type": "object"
    },
    "NonEmptyStr": {
      "minLength": 1,
      "type": "string"
    },
    "ProfileSpec": {
      "additionalProperties": false,
      "description": "Execution semantics for one generated Make profile.",
      "properties": {
        "discovery_scope": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "repository discovery policy"
        },
        "environment_scope": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "uv environment ownership"
        },
        "execution_scope": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "check/test runtime scope"
        },
        "name": {
          "$ref": "#/$defs/MakeProfile",
          "description": "Closed Make profile name"
        },
        "setup_scope": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "setup orchestration scope"
        }
      },
      "required": [
        "name",
        "environment_scope",
        "setup_scope",
        "execution_scope",
        "discovery_scope"
      ],
      "title": "ProfileSpec",
      "type": "object"
    },
    "ProviderSpec": {
      "additionalProperties": false,
      "description": "One GitHub organization and its mandatory branch policy.",
      "properties": {
        "base_url": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "GitHub HTTPS base URL"
        },
        "branch": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Provider branch"
        },
        "name": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Provider key"
        },
        "organization": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "GitHub organization"
        }
      },
      "required": [
        "name",
        "organization",
        "base_url",
        "branch"
      ],
      "title": "ProviderSpec",
      "type": "object"
    },
    "RepositoryRef": {
      "additionalProperties": false,
      "description": "One declared repository and its immutable Git origin contract.",
      "properties": {
        "branch": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Required Git branch"
        },
        "distribution": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Python distribution or repository name"
        },
        "name": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Catalog key"
        },
        "path": {
          "description": "POSIX path relative to its workspace root",
          "format": "path",
          "title": "Path",
          "type": "string"
        },
        "profile": {
          "anyOf": [
            {
              "$ref": "#/$defs/MakeProfile"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Makefile generation profile"
        },
        "provider": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Provider key from the codegen configuration"
        },
        "role": {
          "$ref": "#/$defs/RepositoryRole",
          "description": "Repository role in the declared topology"
        },
        "state": {
          "$ref": "#/$defs/RepositoryState",
          "default": "active",
          "description": "Repository lifecycle state"
        },
        "url": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Canonical GitHub clone URL ending in .git"
        }
      },
      "required": [
        "name",
        "distribution",
        "url",
        "branch",
        "path",
        "role",
        "provider"
      ],
      "title": "RepositoryRef",
      "type": "object"
    },
    "RepositoryRole": {
      "description": "Repository role in a declared workspace topology.",
      "enum": [
        "workspace-root",
        "workspace-member",
        "standalone",
        "content-only",
        "excluded"
      ],
      "title": "RepositoryRole",
      "type": "string"
    },
    "RepositoryState": {
      "description": "Lifecycle state used by repository selection.",
      "enum": [
        "active",
        "content-only",
        "excluded"
      ],
      "title": "RepositoryState",
      "type": "string"
    },
    "ResourceSpec": {
      "additionalProperties": false,
      "description": "One PEP-compliant repository resource root and wheel mapping.",
      "properties": {
        "required": {
          "default": false,
          "description": "Whether every Python project requires the root",
          "title": "Required",
          "type": "boolean"
        },
        "source": {
          "description": "Repository-root-relative resource directory",
          "format": "path",
          "title": "Source",
          "type": "string"
        },
        "wheel_destination": {
          "anyOf": [
            {
              "$ref": "#/$defs/NonEmptyStr"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Package-relative wheel destination with {package_name} support"
        }
      },
      "required": [
        "source"
      ],
      "title": "ResourceSpec",
      "type": "object"
    },
    "ScaffoldBuildSpec": {
      "additionalProperties": false,
      "description": "Configured Python build backend for newly scaffolded projects.",
      "properties": {
        "backend": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "PEP 517 backend"
        },
        "requirements": {
          "description": "Build-system requirements",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "minItems": 1,
          "title": "Requirements",
          "type": "array"
        }
      },
      "required": [
        "backend",
        "requirements"
      ],
      "title": "ScaffoldBuildSpec",
      "type": "object"
    },
    "ScaffoldDependencyProfileSpec": {
      "additionalProperties": false,
      "description": "Dependencies selected by the declared upstream FLEXT facade.",
      "properties": {
        "codegen": {
          "default": [],
          "description": "Code-generation requirements",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "title": "Codegen",
          "type": "array"
        },
        "dev": {
          "default": [],
          "description": "Development and validation requirements",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "title": "Dev",
          "type": "array"
        },
        "runtime": {
          "description": "Runtime requirements",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "minItems": 1,
          "title": "Runtime",
          "type": "array"
        },
        "upstream": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Supported upstream facade package"
        }
      },
      "required": [
        "upstream",
        "runtime"
      ],
      "title": "ScaffoldDependencyProfileSpec",
      "type": "object"
    },
    "ScaffoldGitignoreSectionSpec": {
      "additionalProperties": false,
      "description": "One configured section of the generated Git ignore policy.",
      "properties": {
        "name": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Section heading"
        },
        "patterns": {
          "description": "Ignored path patterns",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "minItems": 1,
          "title": "Patterns",
          "type": "array"
        }
      },
      "required": [
        "name",
        "patterns"
      ],
      "title": "ScaffoldGitignoreSectionSpec",
      "type": "object"
    },
    "ScaffoldPingExampleSpec": {
      "additionalProperties": false,
      "description": "Values for the functional ping example created only by codegen new.",
      "properties": {
        "command_name": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Public CLI command"
        },
        "disabled_reply": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Disabled ping response"
        },
        "enabled_default": {
          "description": "Default runtime enablement",
          "title": "Enabled Default",
          "type": "boolean"
        },
        "help_text": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Public CLI command help"
        },
        "reply": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Enabled ping response"
        },
        "success_message": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "CLI success message"
        }
      },
      "required": [
        "command_name",
        "help_text",
        "success_message",
        "enabled_default",
        "reply",
        "disabled_reply"
      ],
      "title": "ScaffoldPingExampleSpec",
      "type": "object"
    },
    "ScaffoldProjectSpec": {
      "additionalProperties": false,
      "description": "Project metadata policy for newly scaffolded distributions.",
      "properties": {
        "classifiers": {
          "description": "Default PyPI classifiers",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "minItems": 1,
          "title": "Classifiers",
          "type": "array"
        },
        "dependency_profiles": {
          "description": "Upstream dependency profiles",
          "items": {
            "$ref": "#/$defs/ScaffoldDependencyProfileSpec"
          },
          "minItems": 1,
          "title": "Dependency Profiles",
          "type": "array"
        },
        "keywords": {
          "default": [],
          "description": "Default project keywords",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "title": "Keywords",
          "type": "array"
        },
        "readme": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "PEP 621 readme path"
        },
        "supported_licenses": {
          "description": "Licenses with complete templates",
          "items": {
            "$ref": "#/$defs/NonEmptyStr"
          },
          "minItems": 1,
          "title": "Supported Licenses",
          "type": "array"
        }
      },
      "required": [
        "readme",
        "supported_licenses",
        "classifiers",
        "dependency_profiles"
      ],
      "title": "ScaffoldProjectSpec",
      "type": "object"
    },
    "ScaffoldSpec": {
      "additionalProperties": false,
      "description": "Complete typed policy consumed only by new-project templates.",
      "properties": {
        "build": {
          "$ref": "#/$defs/ScaffoldBuildSpec",
          "description": "Build-system policy"
        },
        "gitignore_sections": {
          "description": "Generated Git ignore sections",
          "items": {
            "$ref": "#/$defs/ScaffoldGitignoreSectionSpec"
          },
          "minItems": 1,
          "title": "Gitignore Sections",
          "type": "array"
        },
        "ping_example": {
          "$ref": "#/$defs/ScaffoldPingExampleSpec",
          "description": "Functional scaffold example"
        },
        "project": {
          "$ref": "#/$defs/ScaffoldProjectSpec",
          "description": "Project metadata and dependency policy"
        },
        "resources": {
          "description": "Canonical repository resource roots",
          "items": {
            "$ref": "#/$defs/ResourceSpec"
          },
          "minItems": 1,
          "title": "Resources",
          "type": "array"
        }
      },
      "required": [
        "build",
        "project",
        "resources",
        "ping_example",
        "gitignore_sections"
      ],
      "title": "ScaffoldSpec",
      "type": "object"
    },
    "TemplateEntrySpec": {
      "additionalProperties": false,
      "description": "One scaffold-only template mapping consumed by ``codegen new``.",
      "properties": {
        "delegate": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Canonical rendering delegate"
        },
        "destination": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Tokenized repository-relative destination"
        },
        "overwrite": {
          "default": false,
          "description": "Whether the template owns existing content",
          "title": "Overwrite",
          "type": "boolean"
        },
        "profiles": {
          "description": "Profiles that consume the template",
          "items": {
            "$ref": "#/$defs/MakeProfile"
          },
          "title": "Profiles",
          "type": "array"
        },
        "source": {
          "description": "Template-root-relative source",
          "format": "path",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "source",
        "destination",
        "profiles",
        "delegate"
      ],
      "title": "TemplateEntrySpec",
      "type": "object"
    },
    "TemplatesSpec": {
      "additionalProperties": false,
      "description": "New-project scaffold root and its complete ordered manifest.",
      "properties": {
        "entries": {
          "description": "Complete ordered template manifest",
          "items": {
            "$ref": "#/$defs/TemplateEntrySpec"
          },
          "title": "Entries",
          "type": "array"
        },
        "root": {
          "description": "Package-relative template root",
          "format": "path",
          "title": "Root",
          "type": "string"
        }
      },
      "required": [
        "root",
        "entries"
      ],
      "title": "TemplatesSpec",
      "type": "object"
    },
    "ToolchainSpec": {
      "additionalProperties": false,
      "description": "Python selector and exact uv version shared by generated projects.",
      "properties": {
        "python_minor_version": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Python major.minor tool configuration value"
        },
        "python_required_version": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "PEP 440 project Python requirement"
        },
        "python_version": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Python toolchain version selector"
        },
        "ruff_version": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Exact Ruff version for mise"
        },
        "uv_link_mode": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Portable uv installation link mode"
        },
        "uv_required_version": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "PEP 440 uv required-version expression"
        },
        "uv_version": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Exact uv version"
        }
      },
      "required": [
        "python_version",
        "python_minor_version",
        "python_required_version",
        "ruff_version",
        "uv_version",
        "uv_required_version",
        "uv_link_mode"
      ],
      "title": "ToolchainSpec",
      "type": "object"
    },
    "WorkspaceCatalogRef": {
      "additionalProperties": false,
      "description": "Global pointer to a local workspace topology manifest.",
      "properties": {
        "manifest": {
          "description": "Repository-relative manifest path",
          "format": "path",
          "title": "Manifest",
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Workspace name"
        },
        "repository": {
          "$ref": "#/$defs/NonEmptyStr",
          "description": "Root repository catalog key"
        }
      },
      "required": [
        "name",
        "repository",
        "manifest"
      ],
      "title": "WorkspaceCatalogRef",
      "type": "object"
    }
  },
  "$id": "https://github.com/flext-sh/flext-infra/schemas/codegen.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Complete schema-generating contract for ``config/codegen.yaml``.",
  "properties": {
    "Infra": {
      "$ref": "#/$defs/CodegenConfigNamespaceSpec",
      "description": "FLEXT Infra configuration namespace"
    }
  },
  "required": [
    "Infra"
  ],
  "title": "FLEXT Infra Codegen Configuration",
  "type": "object"
}
