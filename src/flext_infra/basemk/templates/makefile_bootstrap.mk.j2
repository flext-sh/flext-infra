ifneq ("$(wildcard ../base.mk)", "")
include ../base.mk
else
-include base.mk

base.mk: Makefile
	@if python3 -c 'import flext_infra' 2>/dev/null; then \
		python3 -m flext_infra basemk generate --project-name $(PROJECT_NAME) --output $@; \
	elif [ -d .venv ] && .venv/bin/python -c 'import flext_infra' 2>/dev/null; then \
		.venv/bin/python -m flext_infra basemk generate --project-name $(PROJECT_NAME) --output $@; \
	else \
		echo "==> base.mk not found. Bootstrapping standalone environment..."; \
		python3 -m venv .venv; \
		.venv/bin/pip install -q -U pip flext-infra; \
		.venv/bin/python -m flext_infra basemk generate --project-name $(PROJECT_NAME) --output $@; \
	fi
	@test -s $@ || { rm -f $@; exit 1; }

.PHONY: venv
venv: ## Create standalone virtual environment
	@python3 -m venv .venv
	@.venv/bin/pip install -U pip
	@echo "Virtual environment created at .venv"
endif
